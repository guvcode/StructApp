{
  "name": "structapp-api-server",
  "version": "1.0.0",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "NODE_ENV=production npx tsx src/index.ts",
    "build": "tsc",
    "test": "node-pg-migrate up && jest",
    "migrate": "set NODE_TLS_REJECT_UNAUTHORIZED=0 && npx tsx ../../node_modules/node-pg-migrate/bin/node-pg-migrate up",
    "migrate:down": "set NODE_TLS_REJECT_UNAUTHORIZED=0 && npx tsx ../../node_modules/node-pg-migrate/bin/node-pg-migrate down",
    "migrate:prod": "NODE_TLS_REJECT_UNAUTHORIZED=0 npx tsx node_modules/node-pg-migrate/bin/node-pg-migrate up",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "argon2": "^0.41.0",
    "bcryptjs": "^2.4.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "csv-parse": "^5.5.0",
    "docx": "^8.5.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.0",
    "messagebird": "^4.0.0",
    "multer": "^1.4.0",
    "node-cron": "^3.0.0",
    "node-pg-migrate": "^6.2.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.0.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "react-hot-toast": "^2.6.0",
    "resend": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/csv-parse": "^1.1.12",
    "@types/exceljs": "^0.5.3",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.0.0",
    "jest": "^29.0.0",
    "pino-pretty": "^13.1.3",
    "ts-jest": "^29.4.11",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
